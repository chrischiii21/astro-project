---
interface Props {
    title: string;
    description: string;
    iconName: string;
    category: string;
}

const { title, description, iconName, category } = Astro.props;

// Simple icon mapping - you can replace with your preferred icon library
const iconMap: Record<string, string> = {
    code: "💻",
    smartphone: "📱",
    palette: "🎨",
    "trending-up": "📈",
    cloud: "☁️",
    "bar-chart": "📊",
};

const categoryColors: Record<string, string> = {
    development: "bg-blue-100 text-blue-800",
    design: "bg-purple-100 text-purple-800",
    marketing: "bg-green-100 text-green-800",
    infrastructure: "bg-orange-100 text-orange-800",
    analytics: "bg-red-100 text-red-800",
};
---

<div
    class="group bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 p-6 border border-gray-100"
>
    <!-- Icon and Category -->
    <div class="flex items-center justify-between mb-4">
        <div
            class="text-4xl group-hover:scale-110 transition-transform duration-300"
        >
            {iconMap[iconName] || "⚡"}
        </div>
        <span
            class={`px-3 py-1 rounded-full text-xs font-medium ${categoryColors[category] || "bg-gray-100 text-gray-800"}`}
        >
            {category}
        </span>
    </div>

    <!-- Title -->
    <h3
        class="text-xl font-bold text-gray-800 mb-3 group-hover:text-blue-600 transition-colors duration-300"
    >
        {title}
    </h3>

    <!-- Description -->
    <p class="text-gray-600 leading-relaxed mb-4">
        {description}
    </p>

    <!-- Action Button -->
    <div class="pt-4 border-t border-gray-100">
        <button
            class="text-blue-600 hover:text-blue-800 font-medium text-sm flex items-center gap-2 group-hover:gap-3 transition-all duration-300"
        >
            Learn More
            <span class="text-lg">→</span>
        </button>
    </div>
</div>
