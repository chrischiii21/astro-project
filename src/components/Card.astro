---
interface Props {
    title?: string;
    image?: string;
    imageAlt?: string;
}

const { title, image, imageAlt = "" } = Astro.props;
---

<div
    class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300"
>
    {
        image && (
            <img src={image} alt={imageAlt} class="w-full h-48 object-cover" />
        )
    }

    <div class="p-6">
        {title && <h3 class="text-xl font-bold text-gray-800 mb-3">{title}</h3>}

        <div class="text-gray-600">
            <slot />
        </div>
    </div>
</div>
