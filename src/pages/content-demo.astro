---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import { getCollection, type CollectionEntry } from "astro:content";

// Load all features from markdown files
const features = await getCollection("features");
const sortedFeatures = [...features].sort(
    (a, b) => a.data.order - b.data.order,
);

// Load all blog posts
const blogPosts = await getCollection("blog");
const featuredPosts = [...blogPosts].filter((post) => post.data.featured);
---

<Layout>
    <Navbar title="Content Demo" />

    <main class="container mx-auto px-6 py-12">
        <div class="text-center mb-12">
            <h1
                class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-800 mb-4"
            >
                Content from Markdown Files
            </h1>
            <p class="text-lg sm:text-xl text-gray-600 mb-8">
                This page loads content dynamically from .md files!
            </p>
        </div>

        <!-- Features Section -->
        <section class="mb-16">
            <h2 class="text-3xl font-bold text-gray-800 mb-8">Features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {
                    sortedFeatures.map((feature) => (
                        <Card
                            title={feature.data.title}
                            image={feature.data.image}
                            imageAlt={feature.data.title}
                        >
                            <p>{feature.data.description}</p>
                            <div class="mt-4">
                                <Button variant="primary">Learn More</Button>
                            </div>
                        </Card>
                    ))
                }
            </div>
        </section>

        <!-- Blog Posts Section -->
        <section>
            <h2 class="text-3xl font-bold text-gray-800 mb-8">
                Featured Blog Posts
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {
                    featuredPosts.map((post) => (
                        <Card
                            title={post.data.title}
                            image={post.data.image}
                            imageAlt={post.data.title}
                        >
                            <p class="mb-2">{post.data.description}</p>
                            <p class="text-sm text-gray-500 mb-2">
                                By {post.data.author} •{" "}
                                {post.data.date.toLocaleDateString()}
                            </p>
                            {post.data.tags && (
                                <div class="flex flex-wrap gap-2 mb-4">
                                    {[...post.data.tags].map((tag) => (
                                        <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            )}
                            <div class="mt-4">
                                <Button
                                    variant="secondary"
                                    href={`/blog/${post.slug}`}
                                >
                                    Read More
                                </Button>
                            </div>
                        </Card>
                    ))
                }
            </div>
        </section>

        <div class="mt-12 p-6 bg-blue-50 rounded-lg">
            <h3 class="text-xl font-bold text-gray-800 mb-4">
                How This Works:
            </h3>
            <ul class="space-y-2 text-gray-700">
                <li>
                    ✅ Content is stored in <code
                        class="bg-white px-2 py-1 rounded">src/content/</code
                    > folder
                </li>
                <li>
                    ✅ Each collection has a schema defined in <code
                        class="bg-white px-2 py-1 rounded">config.ts</code
                    >
                </li>
                <li>
                    ✅ Use <code class="bg-white px-2 py-1 rounded"
                        >getCollection()</code
                    > to load content
                </li>
                <li>✅ Update content without touching code!</li>
            </ul>
        </div>
    </main>
</Layout>
